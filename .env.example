# ── Application ──────────────────────────────────────────────
APP_NAME=SME Insight Hub
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sme_user:sme_password@postgres:5432/sme_insight_hub
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# PostgreSQL Container
POSTGRES_USER=sme_user
POSTGRES_PASSWORD=sme_password
POSTGRES_DB=sme_insight_hub

# ── Authentication ───────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:4173"]

# ── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# ── OCR ──────────────────────────────────────────────────────
TESSERACT_CMD=tesseract
OCR_LANGUAGE=eng+ben

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Frontend ─────────────────────────────────────────────────
PUBLIC_API_URL=http://localhost:8000/api/v1
